# Convex Configuration
# Internal URL for server-side/SSR communication (container-to-container)
CONVEX_URL=http://convex:3210
# Data directory for Convex
CONVEX_DATA_DIR=convex-data
# Public URL for client-side/browser communication
# This should be the Convex "cloud" origin (no /api suffix). The Convex client will call `${NEXT_PUBLIC_CONVEX_URL}/api/...`.
NEXT_PUBLIC_CONVEX_URL=https://localhost
# Public Convex site URL for auth/http actions (no /api prefix)
NEXT_PUBLIC_CONVEX_SITE_URL=https://localhost
# Server-side Convex site URL (required by @convex-dev/better-auth)
CONVEX_SITE_URL=https://localhost
# Internal Convex site URL for server-side calls (container-to-container)
CONVEX_SITE_INTERNAL_URL=http://convex:3211

# Hub Configuration
SITE_URL=https://localhost
NEXT_PUBLIC_SITE_URL=https://localhost

# Proxy Configuration
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
CADDY_DOMAIN=localhost
# Set to 'true' for self-signed certs (internal/dev), 'false' for Let's Encrypt (public domain)
TLS_INTERNAL=true
# Set to 'true' if running behind external reverse proxy (e.g., Nginx Proxy Manager, Traefik)
# When true, Caddy will only listen on HTTP and won't handle TLS
BEHIND_PROXY=false

# Auto-generated by setup.sh - do not set manually
# CONVEX_DEPLOY_KEY=

# Auth Configuration
BETTER_AUTH_SECRET=fleetctrl_secret_123456
JWT_SECRET=
API_URL=https://localhost/api
ALLOW_REGISTRATION=true
NEXT_PUBLIC_ALLOW_REGISTRATION=true
