# Convex Configuration
# Internal URL for server-side/SSR communication (container-to-container)
CONVEX_URL=http://convex:3210
# Public URL for client-side/browser communication
NEXT_PUBLIC_CONVEX_URL=https://localhost/api

# Hub Configuration
SITE_URL=https://localhost

# Proxy Configuration
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
CADDY_DOMAIN=localhost
# Set to 'true' for self-signed certs (internal/dev), 'false' for Let's Encrypt (public domain)
TLS_INTERNAL=true
# Set to 'true' if running behind external reverse proxy (e.g., Nginx Proxy Manager, Traefik)
# When true, Caddy will only listen on HTTP and won't handle TLS
BEHIND_PROXY=false

# Auto-generated by setup.sh - do not set manually
# CONVEX_DEPLOY_KEY=

# Auth Configuration
BETTER_AUTH_SECRET=fleetctrl_secret_123456
ALLOW_REGISTRATION=true
