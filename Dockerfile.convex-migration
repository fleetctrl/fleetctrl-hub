FROM node:22-alpine

RUN apk add --no-cache libc6-compat
WORKDIR /app

RUN npm install -g pnpm@10.25.0

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY convex ./convex

CMD ["sh", "-c", "pnpm convex deploy --url $CONVEX_SELF_HOSTED_URL --admin-key $CONVEX_SELF_HOSTED_ADMIN_KEY"]